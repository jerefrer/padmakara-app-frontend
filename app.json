{
  "expo": {
    "name": "Padmakara",
    "slug": "padmakara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "padmakara",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "linking": {
      "prefixes": [
        "padmakara://",
        "https://padmakara.app",
        "https://app.padmakara.pt"
      ],
      "config": {
        "screens": {
          "(auth)": {
            "screens": {
              "magic-link": "magic-link",
              "check-email": "check-email"
            }
          },
          "(tabs)": {
            "screens": {
              "index": "",
              "profile": "profile"
            }
          }
        }
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.padmakara.app",
      "icon": "./assets/images/iOS.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.padmakara.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#C4423E"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Padmakara"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#C4423E"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "padmakarapt",
          "project": "react-native"
        }
      ]
    ],
    "extra": {
      "sentryDsn": "https://a0c5633e88bc9febe3d131bd356303e6@o4510993302618112.ingest.de.sentry.io/4510993304256592",
      "router": {},
      "eas": {
        "projectId": "44f66aec-5dc0-409f-88bc-bb467caea177"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "frere-jeremy"
  }
}
